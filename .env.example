# Public site URL used for canonical links, Open Graph images, sitemap, and JSON-LD.
#
# Optional. If unset, the app falls back to Vercel's stable production domain
# (VERCEL_PROJECT_PRODUCTION_URL) when deployed, or localhost when running locally.
#
# Set this once the site has a custom domain, e.g.:
# NEXT_PUBLIC_SITE_URL=https://bodhiprotocol.com
NEXT_PUBLIC_SITE_URL=
