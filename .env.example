# Public site URL used for canonical links, Open Graph images, sitemap, and JSON-LD.
#
# Optional. If unset, the app falls back to Vercel's stable production domain
# (VERCEL_PROJECT_PRODUCTION_URL) when deployed, or localhost when running locally.
#
# Set this once the site has a custom domain, e.g.:
# NEXT_PUBLIC_SITE_URL=https://bodhiprotocol.com
NEXT_PUBLIC_SITE_URL=

# --- Hidden analytics (admin-only dashboard at /admin) ---

# Postgres connection string for the analytics database.
# Create a Neon database from the Vercel dashboard (Storage tab -> Neon Postgres,
# free tier), then copy its connection string here (and into Vercel's env settings).
DATABASE_URL=

# Upstash Redis REST credentials, used only for the live "visitors online now" count.
# Create a Redis database from the Vercel dashboard (Storage tab -> Upstash),
# then copy these two values here (and into Vercel's env settings).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# The password you'll type at /admin/login to unlock the analytics dashboard.
# Pick anything private -- this is the only thing standing between the public
# internet and your visitor data, so don't reuse a password from elsewhere.
ADMIN_PASSWORD=

# Random secret used to sign the admin session cookie so it can't be forged.
# Generate one with: openssl rand -base64 32
ADMIN_SESSION_SECRET=
